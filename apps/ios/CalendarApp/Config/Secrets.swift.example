// MARK: - Secrets template
// Copy this file to Secrets.swift and fill in your own values.
// Secrets.swift is gitignored — never commit real values to source control.

enum Secrets {

    // ── Supabase ─────────────────────────────────────────────────────────────
    // 1. Create a free project at https://supabase.com
    // 2. Settings → API → copy "Project URL" and "anon public" key
    // 3. SQL Editor → run all files in supabase/migrations/ in order
    // 4. Authentication → Providers → Email → enable "Email OTP" (no extra service needed)
    static let supabaseURL     = "https://YOUR_PROJECT_REF.supabase.co"
    static let supabaseAnonKey = "YOUR_SUPABASE_ANON_KEY"

    // ── Google Calendar ───────────────────────────────────────────────────────
    // 1. https://console.cloud.google.com → New Project
    // 2. APIs & Services → Enable: "Google Calendar API" + "Google Sign-In"
    // 3. Credentials → Create OAuth 2.0 Client ID → Application type: iOS
    // 4. Copy the Client ID (ends in .apps.googleusercontent.com)
    // 5. The reversed client ID (com.googleusercontent.apps.XXXXX) must match
    //    the CFBundleURLSchemes entry in project.yml
    static let googleClientID = "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

    // ── Microsoft Outlook ─────────────────────────────────────────────────────
    // 1. https://portal.azure.com → Azure Active Directory → App registrations → New
    // 2. Authentication → Add platform → iOS/macOS → Bundle: your bundle ID
    // 3. API permissions → Add → Microsoft Graph → Delegated: Calendars.Read, User.Read
    // 4. Copy the Application (client) ID from the Overview page
    static let msalClientID    = "YOUR_AZURE_APP_CLIENT_ID"
    static let msalRedirectURI = "msauth.YOUR_BUNDLE_ID://auth"

    // ── Apple Push Notifications (APNs) ──────────────────────────────────────
    // APNs secrets live in Supabase (Edge Function), not the app:
    //    supabase secrets set APNS_KEY_ID=XXXXXXXXXX
    //    supabase secrets set APNS_TEAM_ID=XXXXXXXXXX
    //    supabase secrets set APNS_PRIVATE_KEY="$(cat AuthKey_KEYID.p8)"
    //    supabase secrets set APNS_BUNDLE_ID=YOUR_BUNDLE_ID
}
